FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PORT=8080

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml README_MCP.md ./
COPY agents ./agents

RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -e . \
    && pip install --no-cache-dir "mcp[cli]"

# Runtime data copied after the dependency layer so it stays cached when only
# these change:
#  - .config/clickup_fields.json: ClickUp field/list UUIDs (no secrets). The
#    field schema is loaded regardless of tenant, so ClickUp tools need it.
#  - scripts/: ops scripts incl. migrate.py, runnable via `aws ecs execute-command`.
COPY .config ./.config
COPY scripts ./scripts

# If the existing M365 bot code is not part of the same build context, copy or
# mount it into the image and set M365_AGENT_PATH to that location.
# Example:
#   COPY m365_agent_v2 /app/external/m365_agent_v2
#   ENV M365_AGENT_PATH=/app/external/m365_agent_v2

EXPOSE 8080

CMD ["uvicorn", "agents.mcp.server:app", "--host", "0.0.0.0", "--port", "8080"]
