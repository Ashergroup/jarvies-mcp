# ──────────────────────────────────────────────────────────────
# Jarvies MCP — environment template. Copy to .env for local dev.
# NEVER put real secrets in this file; .env is gitignored, this is not.
# In production (App Runner) these are injected via the Console, not a file.
# ──────────────────────────────────────────────────────────────

# Runtime
ENVIRONMENT=development
PORT=8080
MCP_LOG_LEVEL=INFO

# HTTP auth for /mcp. Use a long random value in production.
# Comma-separated; any one value is accepted as X-API-Key or Bearer token.
MCP_API_KEYS=replace-with-local-api-key
# Local-only convenience bypass. MUST stay false in production (and is ignored
# when ENVIRONMENT=production regardless of this value).
MCP_ALLOW_UNAUTHENTICATED=false

# Optional JWT auth. Use API keys for local testing if JWT is not ready.
MCP_JWT_SECRET=
MCP_JWT_AUDIENCE=
MCP_JWT_ISSUER=

# Default tool context, used only when a tool call omits tenant/user/permissions.
# In production, pass tenant_id, user_id, and permissions per tool call.
# Do NOT include admin_access here in production.
MCP_DEFAULT_TENANT_ID=local
MCP_DEFAULT_USER_ID=local-user
MCP_DEFAULT_PERMISSIONS=

# Existing M365 bot code. This path is read/imported, not rewritten.
# NOTE: this path does not exist on App Runner — M365 tools require the external
# agents.m365 package and are unavailable in the default cloud deploy.
M365_AGENT_PATH=C:/Users/DELL/Documents/agents/m365_agent_v2
M365_DRAFT_UNATTENDED=true

# Existing M365 bot/package settings, required when M365 wrappers import
# agents.m365 modules. Phase 2 OAuth will also use the Azure values.
ANTHROPIC_API_KEY=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# PostgreSQL. Use a dedicated read-only user for MCP database access.
# Optional — leave unset if DB tools are not in use.
DATABASE_URL=postgresql://readonly_user:readonly_password@localhost:5432/appdb
MCP_DB_READONLY=true
MCP_DB_STATEMENT_TIMEOUT_MS=5000
MCP_DB_MAX_ROWS=100
MCP_TOOL_RESULT_LIMIT=50

# ── Xero (Accounting API, OAuth2 refresh-token rotation) ──
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_TENANT_ID=
XERO_REFRESH_TOKEN=
XERO_REDIRECT_URI=http://localhost:8080/xero/callback

# ── Cin7 (DEAR / Cin7 Core External API v2) ──
CIN7_API_KEY=
CIN7_ACCOUNT_ID=
# Uncomment only if your Cin7 is Core (dearsystems), not Omni:
# CIN7_BASE_URL=https://inventory.dearsystems.com/ExternalApi/v2

# ── Freshsales ──
FRESHSALES_DOMAIN=
FRESHSALES_API_KEY=

# ── ClickUp (fundraising: IR + Pipeline lists) ──
# Run scripts/setup_clickup_fields.py locally to (re)generate the JSON file
# pointed at by CLICKUP_CUSTOM_FIELDS_CONFIG_PATH. That file (UUIDs only, no
# secrets) is committed to the repo so the deployed container can read it.
CLICKUP_API_TOKEN=
CLICKUP_TEAM_ID=
CLICKUP_IR_LIST_ID=
CLICKUP_PIPELINE_LIST_ID=
CLICKUP_CUSTOM_FIELDS_CONFIG_PATH=.config/clickup_fields.json
